{
  "manifest_version": 3,
  "name": "LinkedIn Referral Assistant",
  "version": "0.3.0",
  "description": "Personal-use helper for LinkedIn referrals, current-company search, and manual connect-note filling.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/jobs/*",
        "https://www.linkedin.com/jobs/*",
        "https://linkedin.com/jobs/*",
        "https://*.linkedin.com/in/*",
        "https://www.linkedin.com/in/*",
        "https://linkedin.com/in/*",
        "https://*.linkedin.com/search/results/people/*",
        "https://www.linkedin.com/search/results/people/*",
        "https://linkedin.com/search/results/people/*"
      ],
      "js": ["pageAction.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "https://*.vercel.app/*"
      ],
      "js": ["webAppBridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Find Referral",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
